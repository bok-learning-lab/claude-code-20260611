{
  "name": "harvard-art-museums-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the Harvard Art Museums API: search the collection, inspect objects, browse vocabularies and colors, and build IIIF image URLs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "harvard-art-museums-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

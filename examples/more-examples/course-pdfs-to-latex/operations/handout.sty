%% File: handout.sty
%% -----------------
%% Provides a package handout, which can either be called as
%% \usepackage{handout} or \usepackage[sols]{handout}.  The package
%% defines two environments, problem and solution.  When called as
%% \usepackage{handout}, the solution environments will not be displayed.
%% When called as \usepackage[sols]{handout}, the solutions will be
%% displayed.  Also, the problems will be displayed in a different font,
%% namely \problemfont.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{handout}
\RequirePackage{verbatim}

\usepackage{calc}
\usepackage{ifthen}
\usepackage{bm}

\usepackage{enumitem}
\setlist{parsep=8pt}

% create the solution environment, which is really just verbatim's
% comment environment 
\let\solution=\comment
\let\endsolution=\endcomment

% same thing for grading
\let\grading=\comment
\let\endgrading=\endcomment

% and for workshop notes
\let\workshop=\comment
\let\endworkshop=\endcomment

% and for notes

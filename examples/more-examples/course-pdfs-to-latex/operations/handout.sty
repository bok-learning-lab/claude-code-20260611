\let\endplan=\endcomment

\let\problem=\comment
\newcommand{\probspace}{}
\newlength{\problemspace}
\def\@firstchar#1#2\EndMark{\string#1}
\newcommand{\firstChar}[1]{\@firstchar#1\EndMark}

\newcommand{\probspaceFirstChar}{Null}
\renewenvironment{problem}[1][0pt]{%
  \renewcommand{\probspace}{#1}%
  \renewcommand{\probspaceFirstChar}{\firstChar{#1}}%
}{%
  \pspace{\probspace}%
}
\newcommand{\pspace}[1]{%
  \ifthenelse{\equal{\probspaceFirstChar}{Null}}{\renewcommand{\probspaceFirstChar}{\firstChar{#1}}}{}%
  \ifthenelse{\equal{\probspaceFirstChar}{\firstChar{\vfill}}\OR\equal{\probspaceFirstChar}{\firstChar{\newpage}}}{#1}{\vspace{#1}}%
  \renewcommand{\probspaceFirstChar}{Null}%
}

\newenvironment{problemonly}{}{}
\newcommand{\htitle}[1]{\begin{center} \large\textbf{#1} \end{center}}
\newcommand{\stitle}[1]{}
\newcommand{\probonly}[1]{#1}
\newcommand{\solonly}[1]{}
\newcommand{\answer}[1]{\solonly{{\fontshape{n}\textbf{#1}}}}
\newlength{\framemargin}
\usepackage{framed}
\renewenvironment{framed}{
  \setlength{\framemargin}{\textwidth-\linewidth}
  \advance\@totalleftmargin-\framemargin
  %% \advance\width\framemargin
  \def\FrameCommand{\hspace{\framemargin}\fbox}%
  \advance\linewidth\framemargin
  \MakeFramed {\advance\hsize-\width \FrameRestore}%
  %% \MakeFramed {\advance\linewidth-\width \FrameRestore}%
}
{\endMakeFramed}

\usepackage[skins,breakable]{tcolorbox}

\newcommand{\continueproblem}[1]{%
  \probonly{\begin{framed}%
      #1%
    \end{framed}%
  }%
}

\newenvironment{warmup}{}{}

% for fill in the blank things: arguments are width of the blank and the answer
\newcommand{\@fitbans}{}
\newcommand{\@fitbblank}{}
%% \newcommand{\fitb}[2]{%
%%   \ifmmode%
%%   \renewcommand{\@fitbans}{$\bm{#2}$}%
%%   \else%
%%   \renewcommand{\@fitbans}{\textbf{#2}}%
%%   \fi%
%%   \underline{\parbox[t]{#1}{\probonly{\ }\solonly{\@fitbans}}}%
%% }
\newcommand{\fitb}[3][\ ]{%
  \ifmmode%
  \renewcommand{\@fitbans}{$\bm{#3}$}%
  \renewcommand{\@fitbblank}{$#1$}%
  \else%
  \renewcommand{\@fitbans}{\textbf{#3}}%
  \renewcommand{\@fitbblank}{#1}%
  \fi%
  \underline{\parbox[t]{#2}{\probonly{\@fitbblank}\solonly{\@fitbans}}}%
}
% fill in the blank with answer centered
\newcommand{\cfitb}[3][\ ]{%
  \ifmmode%
  \renewcommand{\@fitbans}{\centering$\bm{#3}$}%
  \renewcommand{\@fitbblank}{$#1$}%
  \else%
  \renewcommand{\@fitbans}{\centering\textbf{#3}}%
  \renewcommand{\@fitbblank}{#1}%
  \fi%
  \underline{\parbox[t]{#2}{\probonly{\@fitbblank}\solonly{\@fitbans}}}%
}

\let\solutiononly=\comment
\let\endsolutiononly=\endcomment

% allow circling of items
\usepackage{fancybox}

\provideboolean{doCircle}
\setboolean{doCircle}{false}
\cornersize{1}

\newcommand{\circleitem}{\setboolean{doCircle}{true}\item}
\newcommand{\plainitem}{\setboolean{doCircle}{false}\item}

\newcommand{\maybecircle}[2][\boolean{doCircle}]{\probonly{#2}\solonly{\ifthenelse{#1}{\ovalbox{#2}\hspace{-\fboxrule}\hspace{-\fboxsep}}{#2}}}

% multiple choice
\newenvironment{mc}[1]{%
  \underline{\parbox[t]{0.5in}%
    {\centering\probonly{\ }{\solonly{\textbf{#1}}}}}
  \hspace{6pt} \begin{minipage}[t]{\linewidth-47pt} \setlength{\parskip}{8pt}}
  {\end{minipage}\bigskip}

% true-false

\newlength{\@tfwidth}
\settowidth{\@tfwidth}{\hspace{0.1in} True \hspace{0.2in} False \hspace{0.1in}}
\provideboolean{answerTrue}
\newenvironment{tf}[1]{%
  \ifthenelse%
  {\(\equal{\firstChar{#1}}{\firstChar{T}}\)\OR\(\equal{\firstChar{#1}}{\firstChar{t}}\)}%
  {\setboolean{answerTrue}{true}}%
  {\setboolean{answerTrue}{false}}%
  \parbox[t]{\@tfwidth}{\hspace{0.1in}%
    \maybecircle[\boolean{answerTrue}]{True} \hspace{0.2in}%
    \maybecircle[\NOT\boolean{answerTrue}]{False}%
  }%
  \begin{minipage}[t]{\linewidth-\@tfwidth} \setlength{\parskip}{8pt}}%  
{\end{minipage}\bigskip}

\newcommand\problemfont{} % \fontshape{it} to italicize

% if the nospace option is used, don't show problem space
\DeclareOption{nospace}{%
  \renewenvironment{problem}[1][0pt]{}{}
  \renewcommand{\pspace}[1]{}
  \renewcommand{\continueproblem}[1]{}
  \PassOptionsToPackage{\CurrentOption}{exam}
}

% if the option sols is used, display solutions and hide problem spacing
\DeclareOption{sols}{%
  \renewenvironment{problem}[1][0in]%
  {\def\c@encoding{\f@encoding}% save current encoding in \c@encoding
    \def\c@family{\f@family}%
    \def\c@series{\f@series}%
    \def\c@shape{\f@shape}%
    \problemfont\selectfont% change font
  }%
  {\usefont{\c@encoding}{\c@family}{\c@series}{\c@shape}\selectfont}% restore original shape
  %
  \definecolor{titlecolor}{RGB}{0, 99, 178}
  \definecolor{backcolor}{RGB}{193, 228, 242}
  \renewenvironment{solution}{\begin{tcolorbox}[enhanced, breakable, parbox=false, colback=backcolor, colframe=titlecolor, fonttitle=\bf, boxrule=0pt, toptitle=4pt, bottomtitle=4pt, title=Solution, sharp corners]}{\end{tcolorbox}}%
  \let\problemonly=\comment
  \let\endproblemonly=\endcomment
  \renewcommand{\pspace}[1]{}
  \renewenvironment{solutiononly}{}{}
  \renewcommand{\probonly}[1]{}
  \renewcommand{\solonly}[1]{#1}
}

% if the option showprobonly is used, probonly stuff will be displayed 
\DeclareOption{showprobonly}{%
  \renewenvironment{problemonly}{\ding{100}}{\ding{100}}
  \renewcommand{\probonly}[1]{\ding{100} #1 \ding{100}}
}

% if the solsonly option is used, no problems will be displayed
\DeclareOption{solsonly}{%
  \let\problem=\comment
  \let\endproblem=\endcomment
  \let\problemonly=\comment
  \let\endproblemonly=\endcomment
  \renewcommand{\pspace}[1]{}
  \renewenvironment{solutiononly}{}{}
  \renewcommand{\probonly}[1]{}
  \renewcommand{\solonly}[1]{#1}
  \renewenvironment{solution}{}{}
  \renewcommand{\htitle}[1]{}
  \renewcommand{\stitle}[1]{\begin{center} \large\textbf{#1} \end{center}}
}
  

# Secrets for the class-processor example — copy this file to ".env" and fill in.
#
#   cp .env.example .env
#
# ".env" is git-ignored (see the repo .gitignore: `.env*` is ignored, this
# ".env.example" is the one tracked exception). The keys below live ONLY in this
# example's folder, not at the repo root — so the secret travels with the project
# and nothing leaks if you share the repo.
#
# Only the "apis-and-vision" operation needs these. Everything else in
# class-processor runs without any keys.

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic / Claude — https://console.anthropic.com/settings/keys
# (You already talk to Claude inside Claude Code; this key is only for calling
#  the Claude API directly from the transcribe.py script, to show the raw API.)
ANTHROPIC_API_KEY=

# Optional model overrides (sensible defaults are used if left blank):
# GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_MODEL=claude-opus-4-8
